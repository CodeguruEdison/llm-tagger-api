# ─────────────────────────────────────────────
# llm-tagger-api — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ─── Application ──────────────────────────────
ENVIRONMENT=development               # development | staging | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR

# ─── Database ─────────────────────────────────
# App connects via pgBouncer (port 5432 inside Docker)
# For local development outside Docker, connect directly to Postgres
DATABASE_URL=postgresql+asyncpg://tagger:tagger@localhost:5432/tagger
DATABASE_POOL_SIZE=20                 # asyncpg connection pool size per worker
DATABASE_MAX_OVERFLOW=10             # extra connections beyond pool_size

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0   # general cache + taxonomy
ARQ_REDIS_URL=redis://localhost:6379/1  # ARQ job queue (separate DB)
REDIS_TAXONOMY_TTL=300               # taxonomy cache TTL in seconds (5 min)

# ─── LLM Provider ─────────────────────────────
# Switch between providers by changing this single value:
# ollama | openai | azure_openai | anthropic
LLM_PROVIDER=ollama

# LLM confidence thresholds (0.0 - 1.0)
# Tags below these thresholds are discarded
LLM_CONFIDENCE_PARTS=0.70
LLM_CONFIDENCE_CUSTOMER=0.85         # higher - false positives are disruptive
LLM_CONFIDENCE_INSURANCE=0.80
LLM_CONFIDENCE_PRODUCTION=0.75
LLM_CONFIDENCE_DEFAULT=0.75

# LLM timeout settings
LLM_TIMEOUT_SECONDS=30               # max wait for LLM response
LLM_MAX_RETRIES=2                    # retry attempts on failure

# ─── Ollama (home / local) ────────────────────
# Ollama runs NATIVELY on Mac (not in Docker)
# Mac: install from https://ollama.ai, run: ollama pull gemma2:9b
# Docker containers reach it via host.docker.internal
OLLAMA_BASE_URL=http://localhost:11434   # outside Docker
# OLLAMA_BASE_URL=http://host.docker.internal:11434  # inside Docker
OLLAMA_MODEL=gemma2:9b

# ─── OpenAI ───────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500

# ─── Azure OpenAI (work / production) ─────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_MAX_TOKENS=500

# ─── Langfuse (LLM Observability) ─────────────
# 1. Start stack once: make up
# 2. Open http://localhost:3001, sign up, create a project
# 3. Copy the project's API keys here (Settings → API keys)
# 4. Restart app/worker: make restart
# Keys persist only if you never run "make down" with volumes removed (-v).
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001  # outside Docker
# LANGFUSE_HOST=http://langfuse:3000  # inside Docker (set by compose for app/worker)

# ─── Langfuse Docker (keep API keys stable) ───
# Set these to FIXED random strings and never change them. If they change on
# restart, Langfuse may show different or invalid keys. Do not use "docker compose down -v".
LANGFUSE_NEXTAUTH_SECRET=your-fixed-32-char-secret-here
LANGFUSE_SALT=your-fixed-salt-here
# Generate once with: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=your-fixed-64-char-hex-key-here

# ─── Worker ───────────────────────────────────
WORKER_MAX_JOBS=10                   # concurrent LLM jobs per worker instance
WORKER_JOB_TIMEOUT=60               # seconds before job is considered failed
WORKER_RETRY_JOBS=true
WORKER_MAX_TRIES=3                   # max retry attempts per job

# ─── API ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4                            # uvicorn worker count (production)
                                     # formula: (2 × CPU cores) + 1

# ─── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
